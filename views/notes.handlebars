<div class="flex justify-center mt-12">
    <div class="card inline-block h-max min-h-10 w-max min-w-8">
        <h1 class="font-bold text-sky-50 ">Notes:</h1>
        <ul class="list-disc list-inside">
            
        {{#each notes}}
            <li class="font-bold text-sky-50">{{ note }}</li>
        {{else}}
            <li class="font-bold text-sky-50">Nenhuma nota registrada</li>
        {{/each}}
            <li class="font-bold text-sky-50"><a>aqui vou cadastrar novas</a></li>
        </ul>
    </div>

    <div class="card inline-block h-max w-max">
        <div class="flex gap-5">
            <h1 class="font-bold text-sky-50">Daily Goals</h1>
            <h1 class="font-bold text-sky-50">Weekly Goals</h1>
        </div>
        
    </div>
</div>